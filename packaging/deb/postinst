#!/bin/sh
set -e

install -d -o root -g root -m 0755 /etc/resguard
install -d -o root -g root -m 0755 /etc/resguard/profiles
install -d -o root -g root -m 0755 /etc/systemd/system
install -d -o root -g root -m 0755 /var/lib/resguard

if [ -f /usr/share/resguard/systemd/resguardd.service ]; then
  install -o root -g root -m 0644 /usr/share/resguard/systemd/resguardd.service /etc/systemd/system/resguardd.service
fi

if [ ! -f /etc/resguard/resguardd.yml ] && [ -f /usr/share/resguard/resguardd.yml ]; then
  install -o root -g root -m 0644 /usr/share/resguard/resguardd.yml /etc/resguard/resguardd.yml
fi

if command -v systemctl >/dev/null 2>&1; then
  systemctl daemon-reload >/dev/null 2>&1 || true
fi

exit 0
